const blockedIPs = new Set();
function validateNodeLayer(ws,data){
  if(blockedIPs.has(ws._socket.remoteAddress)) return false;
  const entry = whitelistNodes[data.nodeId];
  if(!entry || entry.token!==data.token) { blockedIPs.add(ws._socket.remoteAddress); console.log(`[BLOCKED] Node ${data.nodeId} IP ${ws._socket.remoteAddress} invalid token`); return false; }
