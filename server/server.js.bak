const behaviorDB={};
function analyzeBehavior(ip,endpoint){
  const now=Date.now();
  if(!behaviorDB[ip]){
    behaviorDB[ip]={
      endpoints:{},
      firstSeen:now,
      lastSeen:now,
      anomalies:0
    };
  }
  const entry=behaviorDB[ip];
  entry.lastSeen=now;
  if(!entry.endpoints[endpoint]){
    entry.endpoints[endpoint]=0;
  entry.endpoints[endpoint]++;
  // anomaly rules
  let anomaly=false;
  // hitting many different endpoints quickly
  const uniqueEndpoints=Object.keys(entry.endpoints).length;
  if(uniqueEndpoints>10){
    anomaly=true;
  // heavy focus on login
  if(endpoint.includes("login") && entry.endpoints[endpoint]>20){
  if(anomaly){
    entry.anomalies++;
    const report={
      type:"behavior_anomaly",
      ip,
      endpoint,
      anomalies:entry.anomalies,
      time:now
    console.log("[ANOMALY DETECTED]",report);
    // raise threat score
    processThreat(ip,"behavior-anomaly",endpoint,"behavior-engine");
    // notify dashboard
    clients.forEach(c=>{
      if(c.ws && c.ws.readyState===1){
        c.ws.send(JSON.stringify(report));
    });
    // send to AI socket
    sendToAI(report);
