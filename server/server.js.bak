let clients = [];
let whitelist = {
  'NODE_001': { token:'abc123', capabilities:{ scan:true, logs:true, manualStop:false, autoStop:false } },
  'NODE_002': { token:'xyz789', capabilities:{ scan:true, logs:true, manualStop:true, autoStop:false } }
};
function blockNode(ws, reason){
  if(ws.nodeId) console.log(`[BLOCKED] Node ${ws.nodeId} blocked: ${reason}`);
  ws.close();
}
wss.on('connection', ws => {
  ws.isAuthorized = false;
  ws.on('message', msg => {
    try {
      const data = JSON.parse(msg);
      if(data.action==='register'){
        const entry = whitelist[data.nodeId];
        if(entry && data.token===entry.token){
          ws.nodeId = data.nodeId;
          ws.capabilities = entry.capabilities;
          ws.isAuthorized = true;
          clients.push(ws);
          ws.send(JSON.stringify({message:'Node registered successfully'}));
          console.log(`[INFO] Node ${ws.nodeId} registered`);
        } else { blockNode(ws,'Invalid registration'); }
        return;
      }
      if(!ws.isAuthorized){ blockNode(ws,'Unauthorized'); return; }
      if(data.action==='scan' && ws.capabilities.scan){ broadcast({scan:{target:data.target||'example.com',vulnerability:'SQL Injection',severity:'High',timestamp:Date.now()}}); return; }
      if(data.action==='logs' && ws.capabilities.logs){ console.log(`[LOG] Node ${ws.nodeId}: ${JSON.stringify(data.content)}`); return; }
      if(data.action==='manual-stop'){ if(ws.capabilities.manualStop){ broadcast({log:`Manual Stop executed by ${ws.nodeId}`}); return; } else { blockNode(ws,'Unauthorized manual stop attempt'); return; } }
      if(data.action==='auto-stop'){ if(ws.capabilities.autoStop){ broadcast({log:`Auto Stop executed by ${ws.nodeId}`}); return; } else { blockNode(ws,'Unauthorized auto stop attempt'); return; } }
      if(data.action==='heartbeat'){ ws.send(JSON.stringify({message:'alive'})); return; }
      blockNode(ws,'Unknown action');
  });
  ws.on('close', ()=>{ clients = clients.filter(c=>c!==ws); });
  ws.send(JSON.stringify({client:{coins:150,tier:'Basic'}}));
});
function broadcast(data){ clients.forEach(c=>{ if(c.readyState===WebSocket.OPEN) c.send(JSON.stringify(data)); }); }
